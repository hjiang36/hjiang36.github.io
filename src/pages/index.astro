---
import data from '../content/data.json';
import About from '../components/About.astro';
import Hero from '../components/Hero.astro';
import ResearchPanel from '../components/ResearchPanel.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout site={data.site}>
  <a class="fixed left-4 top-4 z-50 -translate-y-20 bg-ink px-4 py-2 font-mono text-xs text-paper focus:translate-y-0" href="#content">{data.site.skipLabel}</a>
  <SiteHeader name={data.profile.name} handle={data.profile.handle} navigation={data.site.navigation} navigationLabel={data.site.navigationLabel} />
  <main id="content">
    <Hero profile={data.profile} hero={data.hero} />
    <ResearchPanel research={data.research} />
    <About about={data.about} links={data.profile.links} />
  </main>
  <SiteFooter name={data.profile.name} copyright={data.site.copyright} builtWith={data.site.builtWith} footerLabel={data.site.footerLabel} />
</BaseLayout>
---
interface Point {
  title: string;
  body: string;
}

interface Section {
  title: string;
  paragraphs: string[];
  points: Point[];
}

interface Props {
  article: {
    label: string;
    title: string;
    date: string;
    datetime: string;
    readTime: string;
    summary: string;
    tags: string[];
    backLabel: string;
    sections: Section[];
  };
}

const { article } = Astro.props;
---

<main class="border-b border-ink/20" id="content">
  <article>
    <header class="border-b border-ink/20">
      <div class="mx-auto max-w-7xl px-5 py-16 sm:px-8 sm:py-24 lg:px-12">
        <div class="grid gap-10 md:grid-cols-12">
          <div class="md:col-span-3">
            <p class="font-mono text-xs uppercase text-signal">{article.label}</p>
          </div>
          <div class="md:col-span-8">
            <h1 class="max-w-4xl break-words text-4xl font-semibold leading-[1.08] tracking-normal sm:text-6xl">{article.title}</h1>
            <p class="mt-8 max-w-3xl text-xl leading-relaxed text-muted">{article.summary}</p>
            <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3 font-mono text-xs text-muted">
              <time datetime={article.datetime}>{article.date}</time>
              <span aria-hidden="true">/</span>
              <span>{article.readTime}</span>
            </div>
            <ul class="mt-6 flex flex-wrap gap-x-4 gap-y-2 font-mono text-[0.6875rem] uppercase text-muted" aria-label="Topics">
              {article.tags.map((tag) => <li>#{tag}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-7xl px-5 sm:px-8 lg:px-12">
      {article.sections.map((section, index) => (
        <section class="grid gap-8 border-b border-ink/20 py-14 last:border-b-0 sm:py-20 md:grid-cols-12">
          <div class="md:col-span-3">
            <p class="font-mono text-xs text-muted">{String(index + 1).padStart(2, '0')}</p>
          </div>
          <div class="md:col-span-8">
            <h2 class="break-words text-3xl font-semibold tracking-normal sm:text-4xl">{section.title}</h2>
            <div class="mt-8 space-y-6 text-lg leading-[1.8]">
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
            {section.points.length > 0 && (
              <ol class="mt-10 border-t border-ink/20">
                {section.points.map((point, pointIndex) => (
                  <li class="grid gap-4 border-b border-ink/20 py-7 sm:grid-cols-[2rem_1fr]">
                    <span class="font-mono text-xs text-signal">{String(pointIndex + 1).padStart(2, '0')}</span>
                    <div>
                      <h3 class="text-xl font-semibold">{point.title}</h3>
                      <p class="mt-3 text-base leading-relaxed text-muted">{point.body}</p>
                    </div>
                  </li>
                ))}
              </ol>
            )}
          </div>
        </section>
      ))}
    </div>

    <div class="mx-auto max-w-7xl px-5 pb-16 pt-4 sm:px-8 sm:pb-24 lg:px-12">
      <div class="md:ml-[25%]">
        <a class="inline-block border-b border-ink font-mono text-xs uppercase hover:border-signal hover:text-signal" href="/memo/">{article.backLabel}</a>
      </div>
    </div>
  </article>
</main>
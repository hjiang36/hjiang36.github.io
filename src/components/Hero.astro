---
interface Link { label: string; href: string }
interface Props {
  profile: {
    name: string;
    role: string;
    location: string;
    affiliation: string;
    avatar: string;
    avatarAlt: string;
    availability: string;
    intro: string;
    links: Link[];
  };
  hero: { eyebrow: string; prompt: string; command: string; scrollHint: string };
}

const { profile, hero } = Astro.props;
---

<section class="relative overflow-hidden border-b border-ink/20" id="top">
  <div class="pointer-events-none absolute inset-0 opacity-50 [background-image:linear-gradient(to_right,#d9d7ce_1px,transparent_1px),linear-gradient(to_bottom,#d9d7ce_1px,transparent_1px)] [background-size:48px_48px]"></div>
  <div class="relative mx-auto max-w-7xl px-5 py-12 sm:px-8 sm:py-16 lg:px-12 lg:py-20">
    <div class="mb-16 flex items-start justify-between gap-6 sm:mb-24">
      <div class="font-mono text-xs leading-6">
        <p class="text-signal">{hero.eyebrow}</p>
        <p><span class="text-muted">{hero.prompt} $</span> {hero.command}</p>
      </div>
      <img class="size-20 border border-ink object-cover saturate-[.45] contrast-[1.05] sm:size-28" src={profile.avatar} alt={profile.avatarAlt} width="112" height="112" loading="eager" />
    </div>

    <p class="mb-4 max-w-2xl font-mono text-xs uppercase tracking-normal text-muted">{profile.role} / {profile.affiliation}</p>
    <h1 class="max-w-5xl text-6xl font-semibold leading-[0.88] tracking-normal sm:text-8xl lg:text-[9rem]">{profile.name}</h1>

    <div class="mt-12 grid gap-10 border-t border-ink/30 pt-6 md:grid-cols-12">
      <p class="max-w-xl text-xl leading-relaxed md:col-span-7 md:text-2xl">{profile.intro}</p>
      <div class="md:col-span-4 md:col-start-9">
        <p class="mb-5 font-mono text-xs leading-5 text-muted">{profile.availability}</p>
        <p class="mb-5 font-mono text-xs uppercase">{profile.location}</p>
        <ul class="flex flex-wrap gap-x-5 gap-y-3 font-mono text-sm">
          {profile.links.map((link) => (
            <li><a class="border-b border-ink hover:border-signal hover:text-signal" href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-16 border-t border-ink/20 pt-6 font-mono text-[0.7rem] uppercase text-muted">{hero.scrollHint}</p>
  </div>
</section>